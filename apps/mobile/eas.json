{
    "cli": {
        "version": ">= 18.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "autoIncrement": true
        },
        "preview": {
            "distribution": "internal",
            "autoIncrement": true,
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "autoIncrement": true,
            "distribution": "store",
            "env": {
                "EXPO_NO_DOCTOR": "1"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "track": "production"
            }
        }
    }
}
